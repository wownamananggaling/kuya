section .data
; ===== UI =====
title db 10,"==== 5S QUIZ GAME ====",10
title_len equ $ - title

line db "----------------------",10
line_len equ $ - line

; ===== QUESTIONS =====
q1 db "Sort removes unnecessary items?",10,"1.Yes 2.No: "
q1_len equ $ - q1

q2 db 10,"Shine means cleaning?",10,"1.Yes 2.No: "
q2_len equ $ - q2

q3 db 10,"Sustain means discipline?",10,"1.Yes 2.No: "
q3_len equ $ - q3

; ===== FEEDBACK =====
correct db "✔ Correct!",10
correct_len equ $ - correct

wrong db "✘ Wrong!",10
wrong_len equ $ - wrong

win db 10,"🎉 YOU WIN!",10
win_len equ $ - win

lose db 10,"💀 GAME OVER!",10
lose_len equ $ - lose

score_txt db "Score: "
score_len equ $ - score_txt

lives_txt db " Lives: "
lives_len equ $ - lives_txt

section .bss
input resb 2
score resb 1
lives resb 1

section .text
global _start

_start:
    mov byte [score], 0
    mov byte [lives], 3

    ; show title
    mov rsi, title
    mov rdx, title_len
    call print

game_start:
    cmp byte [lives], 0
    je game_over

    ; show status
    call show_status

    ; ask questions
    call ask_q1
    call check_life
    call ask_q2
    call check_life
    call ask_q3
    call check_life

    jmp win_game

; ===== QUESTIONS =====
ask_q1:
    mov rsi, q1
    mov rdx, q1_len
    call ask
    cmp byte [input], '1'
    call check
    ret

ask_q2:
    mov rsi, q2
    mov rdx, q2_len
    call ask
    cmp byte [input], '1'
    call check
    ret

ask_q3:
    mov rsi, q3
    mov rdx, q3_len
    call ask
    cmp byte [input], '1'
    call check
    ret

; ===== CHECK ANSWER =====
check:
    je right

wrong_ans:
    dec byte [lives]
    mov rsi, wrong
    mov rdx, wrong_len
    call print
    ret

right:
    inc byte [score]
    mov rsi, correct
    mov rdx, correct_len
    call print
    ret

check_life:
    cmp byte [lives], 0
    je game_over
    ret

; ===== STATUS DISPLAY =====
show_status:
    mov rsi, line
    mov rdx, line_len
    call print

    ; print score
    mov rsi, score_txt
    mov rdx, score_len
    call print

    mov al, [score]
    add al, '0'
    mov [input], al
    mov rsi, input
    mov rdx, 1
    call print

    ; print lives
    mov rsi, lives_txt
    mov rdx, lives_len
    call print

    mov al, [lives]
    add al, '0'
    mov [input], al
    mov rsi, input
    mov rdx, 1
    call print

    mov rsi, line
    mov rdx, line_len
    call print
    ret

; ===== ASK =====
ask:
    call print
    call input_read
    ret

; ===== ENDINGS =====
win_game:
    mov rsi, win
    mov rdx, win_len
    call print
    jmp exit

game_over:
    mov rsi, lose
    mov rdx, lose_len
    call print

exit:
    mov rax, 60
    xor rdi, rdi
    syscall

; ===== BASIC IO =====
print:
    mov rax, 1
    mov rdi, 1
    syscall
    ret

input_read:
    mov rax, 0
    mov rdi, 0
    mov rsi, input
    mov rdx, 2
    syscall
    ret
