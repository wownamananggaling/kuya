section .data
    message db "The 5S system is a method for organizing and maintaining a clean, efficient workplace.", 10
            db "It includes five steps:", 10
            db "1. Sort (remove unnecessary items)", 10
            db "2. Set in Order (arrange needed items properly)", 10
            db "3. Shine (clean regularly)", 10
            db "4. Standardize (create consistent rules)", 10
            db "5. Sustain (maintain discipline)", 10, 10
            db "Objectives:", 10
            db "- Improve organization", 10
            db "- Increase productivity", 10
            db "- Enhance safety", 10
            db "- Reduce waste", 10
            db "- Promote responsibility in the workplace", 10
    msg_len equ $ - message

section .text
    global _start

_start:
    ; write(stdout, message, msg_len)
    mov rax, 1          ; syscall: write
    mov rdi, 1          ; stdout
    mov rsi, message    ; pointer
    mov rdx, msg_len    ; length
    syscall

    ; exit(0)
    mov rax, 60         ; syscall: exit
    xor rdi, rdi        ; status 0
    syscall
