.MODEL SMALL
.STACK 100H

.DATA
msg1 DB "Step 1: Sort (Remove unnecessary items)$"
msg2 DB 0DH,0AH,"Step 2: Set in Order (Arrange properly)$"
msg3 DB 0DH,0AH,"Step 3: Shine (Clean the area)$"
msg4 DB 0DH,0AH,"Step 4: Standardize (Follow rules)$"
msg5 DB 0DH,0AH,"Step 5: Sustain (Maintain discipline)$"

.CODE
MAIN PROC

    MOV AX, @DATA
    MOV DS, AX

    ; Display Step 1
    LEA DX, msg1
    MOV AH, 09H
    INT 21H

    ; Display Step 2
    LEA DX, msg2
    MOV AH, 09H
    INT 21H

    ; Display Step 3
    LEA DX, msg3
    MOV AH, 09H
    INT 21H

    ; Display Step 4
    LEA DX, msg4
    MOV AH, 09H
    INT 21H

    ; Display Step 5
    LEA DX, msg5
    MOV AH, 09H
    INT 21H

    ; Exit program
    MOV AH, 4CH
    INT 21H

MAIN ENDP
END MAIN
